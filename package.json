{
  "name": "pty-mgr",
  "version": "1.1.2",
  "description": "PTY session manager with terminal emulation for programmatic session control.",
  "type": "module",
  "main": "lib/pty-manager.mjs",
  "exports": {
    ".": {
      "import": "./lib/pty-manager.mjs"
    }
  },
  "bin": {
    "pty-mgr": "bin/pty-mgr",
    "p": "bin/pty-mgr"
  },
  "scripts": {
    "demo": "bun bin/pty-mgr demo",
    "build": "bun build bin/pty-mgr.mjs --compile --outfile dist/pty-mgr"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pty",
    "terminal",
    "session",
    "agent",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/maarco/pty-mgr.git"
  },
  "license": "MIT"
}
